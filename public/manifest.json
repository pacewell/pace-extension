{
  "manifest_version": 3,
  "name": "Pace — A Pomodoro Timer for Building Your Working Pace",
  "version": "0.1.0",
  "description": "See your finishing time before you start. Pace plans the whole run — breaks and all — so you build a working pace you can keep.",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "alarms", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": false
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Pace",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
